# Ollama HTTP API (default matches a local `ollama serve`).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Text embedding model for FAISS (pull separately from the chat model).
# Example: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# Local LLM for grounded answers (JSON output). Fast default for text QA:
# Example: ollama pull llama3.2:3b
OLLAMA_LLM_MODEL=llama3.2:3b

# Maximum tokens generated per answer (384 balances speed and completeness).
OLLAMA_NUM_PREDICT=384
